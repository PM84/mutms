{{!
    @template block_muprogmyoverview/favouriteicon

    This template renders the favourite icon for a program.

    Example context (json):
    {
        "id": 3,
        "isfavourite": true
    }
}}
<span id="favorite-icon-{{ id }}-{{ uniqid }}"
    data-region="favourite-icon"
    data-program-id="{{id}}"
    >
    <span
        class="text-primary {{^isfavourite}}hidden{{/isfavourite}}"
        data-region="is-favourite"
        aria-hidden="{{^isfavourite}}true{{/isfavourite}}{{#isfavourite}}false{{/isfavourite}}"
        >
        {{#pix}} i/star, core, {{#str}} favourite, tool_muprog {{/str}} {{/pix}}
        <span class="sr-only">{{#str}} favourite, tool_muprog {{/str}}</span>
    </span>
</span>
