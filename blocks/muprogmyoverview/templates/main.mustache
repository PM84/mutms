{{!
    @template block_muprogmyoverview/main

    This template renders the main content area for the muprogmyoverview block.

    Example context (json):
    {}
}}

<div id="block-muprogmyoverview-{{uniqid}}" class="block-muprogmyoverview block-cards" data-region="muprogmyoverview" role="navigation">
    <div role="search" data-region="filter" class="d-flex align-items-center my-2" aria-label="{{#str}} aria:controls, block_muprogmyoverview {{/str}}">
        <div class="row g-0">
            {{> block_muprogmyoverview/nav-grouping-selector }}

            {{> block_muprogmyoverview/nav-search-widget }}

            {{> block_muprogmyoverview/nav-sort-selector }}

            {{#displaydropdown}}
                {{> block_muprogmyoverview/nav-display-selector }}
            {{/displaydropdown}}
        </div>
    </div>

    <div class="container-fluid p-0">
        {{> block_muprogmyoverview/programs-view }}
    </div>
</div>
{{#js}}
require(
[
    'jquery',
    'block_muprogmyoverview/main',
],
function(
    $,
    Main
) {
    var root = $('#block-muprogmyoverview-{{uniqid}}');
    Main.init(root);
});
{{/js}}
