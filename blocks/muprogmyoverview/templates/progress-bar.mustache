{{!
    @template block_muprogmyoverview/progress-bar

    This template renders a simple progress bar.

    Example context (json):
    {
        "progress": 50
    }
}}
<div class="progress-text">
    <span class="sr-only">{{#str}}aria:programprogress, block_muprogmyoverview{{/str}}</span>
    {{#str}}completepercent, block_muprogmyoverview, <span>{{progress}}</span>{{/str}}
</div>
