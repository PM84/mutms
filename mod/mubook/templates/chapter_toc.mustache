{{!
    @template mod_mubook/chapter_toc

    List of subchapters.

    Example context (json):
    {
        "usecolumns": true,
        "subchapters": [
            {
                "chapterid": "123",
                "numbers": "1.1",
                "url": "https://example.com/mod/mubook/viewchapter.php?id=123",
                "title": "Some subchapter",
                "actions": "<div>actions</div>"
            }
        ]
    }

}}
<ul class="mubook-subchapters p-0 {{#usecolumns}}mubook-columns{{/usecolumns}}">
    {{#subchapters}}
        <li id="mubook-chapter-{{chapterid}}" class="mubook-subchapter d-flex">
            {{#numbers}}<span class="mubook-chapter-numbers">{{.}}</span>{{/numbers}}
            <span class="mubook-chapter-title d-block"><a href="{{{url}}}">{{{title}}}</a></span>
            {{{actions}}}
        </li>
    {{/subchapters}}
</ul>
