{{!
    @template block_muprogmyoverview/no-programs

    This template renders the no programs message.

    Example context (json):
    {
        "noprogramsimgurl": "https://moodlesite/theme/image.php/boost/block_recentlyaccessedprograms/1535727318/programs"
    }
}}
<div class="text-xs-center text-center mt-3" data-region="empty-message">
    <img class="empty-placeholder-image-lg mt-1"
         src="{{noprogramsimg}}"
         alt="">
    <p class="text-muted mt-3">{{$noprogramstring}}{{#str}} noprograms, block_muprogmyoverview {{/str}}{{/noprogramstring}}</p>
</div>
