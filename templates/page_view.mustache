{{!
    @template mod_mubook/page_view

    Main TOC of book.

    Example context (json):
    {
        "chapters": [
            {
                "chapterid": "123",
                "numbers": "1",
                "url": "https://example.com/mod/mubook/viewchapter.php?id=123",
                "title": "Some chapter",
                "actions": "<div>actions</div>",
                "has_subchapters": true,
                "subchapters": [
                    {
                        "chapterid": "124",
                        "numbers": "1.1",
                        "url": "https://example.com/mod/mubook/viewchapter.php?id=124",
                        "title": "Some sub-chapter",
                        "actions": "<div>actions</div>"
                    },
                    {
                        "chapterid": "140",
                        "numbers": "1.2",
                        "url": "https://example.com/mod/mubook/viewchapter.php?id=140",
                        "title": "Other sub-chapter",
                        "actions": "<div>actions</div>"
                    }
                ]
            }
        ],
        "orphaned": {
                "subchapters": [
                    {
                        "chapterid": "456",
                        "numbers": "",
                        "url": "https://example.com/mod/mubook/viewchapter.php?id=456",
                        "title": "Broken sub-chapter",
                        "actions": "<div>actions</div>"
                    }
                ]
        },
        "navigation": {
            "previous": [
            ],
            "next": {
                "url": "https://example.com/mod/mubook/viewchapter.php?id=321",
                "title": "Other chapter"
            }
        }
    }

}}
<div class="mubook-page">
    <div id="mubook-toc">
        {{#chapters}}
            <div id="mubook-chapter-{{chapterid}}" class="h3 mubook-chapter-title"><a class="h4" href="{{{url}}}">{{{title}}}</a>{{{actions}}}</div>
            {{#has_subchapters}}
                {{> mod_mubook/chapter_toc}}
            {{/has_subchapters}}
        {{/chapters}}
        {{#orphaned}}
            <div id="mubook-chapter-{{chapterid}}" class="h3 mubook-orphaned-title h4 text-danger pt-4">{{#str}}subchapters_orphaned,mod_mubook{{/str}}</div>
            {{> mod_mubook/chapter_toc}}
        {{/orphaned}}
    </div>
    {{> mod_mubook/navigation}}
</div>
