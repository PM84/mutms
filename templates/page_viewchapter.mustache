{{!
    @template mod_mubook/page_viewchapter

    Book chapter.

    Example context (json):
    {
        "chapterid": "12",
        "title": "Prvni kapitola",
        "tags": "<div>tags</div>",
        "has_subchapters": true,
        "actions": "<div>actions</div>",
        "subchapters": [
            {
                "chapterid": "123",
                "numbers": "1.1",
                "url": "https://example.com/mod/mubook/viewchapter.php?id=123",
                "title": "Some sub-chapter",
                "actions": "<div>actions</div>"
            },
            {
                "chapterid": "140",
                "numbers": "1.2",
                "url": "https://example.com/mod/mubook/viewchapter.php?id=140",
                "title": "Other sub-chapter",
                "actions": "<div>actions</div>"
            }
        ],
        "navigation": {
            "previous": {
                "url": "https://example.com/mod/mubook/viewchapter.php?id=123",
                "title": "Some chapter"
            },
            "next": {
                "url": "https://example.com/mod/mubook/viewchapter.php?id=321",
                "title": "Other chapter"
            }
        }
    }

}}
<article class="mubook-page">
    <div id="mubook-chapter-{{chapterid}}" class="mubook-chapter">
        {{#actions}}<div class="float-end position-relative">{{{.}}}</div> {{/actions}}
        {{#title}}<h2 class="mubook-chapter-title mb-5">{{{.}}}</h2>{{/title}}
        {{#tags}}{{{.}}}{{/tags}}
        {{{contents}}}
        {{#has_subchapters}}
        <hr class="mt-5">
        <div id="mubook-toc">
            {{> mod_mubook/chapter_toc}}
        </div>
        {{/has_subchapters}}
        {{> mod_mubook/navigation}}
    </div>
</article>
