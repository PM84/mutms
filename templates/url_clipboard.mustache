{{!
    @template tool_mulib/url_clipboard

    Template to display a link with copy to clipboard button.

    Context variables required for this template:
    * url - URL
    * copylabel - copy action label

    Example context (json):
    {
        "url": "https://example.com/login/?tenant=TEN1",
        "copylabel": "Copy tenant login URL to clipboard"
    }
}}
{{#url}}
    <span>
        <span id="tool_mulib_ti_{{uniqid}}">{{url}}</span>
        <a href="#"
           data-action="copytoclipboard" data-clipboard-target="#tool_mulib_ti_{{uniqid}}"
           data-clipboard-success-message="{{#str}}textcopiedtoclipboard{{/str}}"
           title="{{copylabel}}"
        >{{#pix}}t/copy, core{{/pix}}</a>
    </span>
    {{#js}}
        require(['core/copy_to_clipboard']);
    {{/js}}
{{/url}}
