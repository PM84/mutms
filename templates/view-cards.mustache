{{!
    @template block_muprogmyoverview/view-cards

    This template renders the cards view for the muprogmyoverview block.

    Example context (json):
    {
        "programs": [
            {
                "name": "Assignment due 1",
                "viewurl": "https://moodlesite/program/view.php?id=2",
                "programimage": "https://moodlesite/pluginfile/123/program/overviewfiles/123.jpg",
                "fullname": "Program 3 for \"Statistical and Computational Tools\" ",
                "hasprogress": true,
                "progress": 10,
                "programcategory": "Category 1"
            }
        ]
    }
}}

{{< block_muprogmyoverview/programcards }}
    {{$menu}}
        <div class="card-footer menu border-0 bg-white ms-auto">
            {{> block_muprogmyoverview/program-action-menu }}
        </div>
    {{/menu}}
    {{$progress}}
        {{#hasprogress}}
            <div class="card-footer border-0 bg-white w-100">
                {{> block_muprogmyoverview/progress-bar}}
            </div>
        {{/hasprogress}}
    {{/progress}}
    {{$programname}}
        <span class="multiline" title="{{fullname}}">
            <span class="sr-only">{{{fullname}}}</span>
            <span aria-hidden="true">
                {{#shortentext}}55, {{{fullname}}} {{/shortentext}}
            </span>
        </span>
    {{/programname}}
    {{$programcategory}}
        {{#showprogramcategory}}
            <span class="sr-only">
                {{#str}}programcategory, tool_muprog{{/str}}
            </span>
            <span class="categoryname text-truncate">
                {{{programcategory}}}
            </span>
        {{/showprogramcategory}}
    {{/programcategory}}
    {{$divider}}
        {{#showprogramcategory}}
            <div class="px-1">|</div>
        {{/showprogramcategory}}
    {{/divider}}
{{/ block_muprogmyoverview/programcards }}
